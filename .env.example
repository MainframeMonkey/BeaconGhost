# Copy this file to .env and fill in your WiGLE API credentials.
#   cp .env.example .env
#   chmod 600 .env
# Do not commit .env. It is ignored by Git (see .gitignore).

WIGLE_API_NAME=replace_me
WIGLE_API_TOKEN=replace_me

# Capture defaults
WIFI_INTERFACE=wlan0
WIFI_CHANNEL=6
CAPTURE_DURATION=60

# File locations
EVENTS_CSV=data/input/ssid_events.csv
WIGLE_RESULTS_CSV=data/results/wigle_results.csv
WIGLE_CACHE=data/cache/wigle_cache.json

# Dashboard source filter: probe_request, beacon, or all
DASHBOARD_SOURCE_FILTER=probe_request

# WiGLE lookup limits
WIGLE_FRAME_TYPE=probe_request
WIGLE_MAX_RESULTS_PER_SSID=10
WIGLE_SLEEP_SECONDS=2.0
WIGLE_MAX_NEW_LOOKUPS_PER_RUN=10
WIGLE_COORD_PRECISION=3
